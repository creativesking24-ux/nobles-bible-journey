# YouVersion Platform — https://platform.youversion.com
# Create an organization + app, accept Bible licenses, then paste your App Key.
# NEVER use VITE_ prefix for the secret key (that would expose it in the browser).

YVP_APP_KEY=your_youversion_app_key_here

# Optional: Bible version ID from the YouVersion catalog after licensing.
# Docs example uses 3034 (BSB). Set to the ID you have licensed (e.g. NIV if approved).
VITE_YVP_BIBLE_ID=3034
